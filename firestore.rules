rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /siteConfig/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /analytics/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /videos/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /brands/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /comments/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /media/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
